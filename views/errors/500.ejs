<section class="d-flex align-items-center justify-content-center" style="min-height:100vh;margin-top:80px;">
  <div class="text-center">
    <h1 class="display-1 fw-bold text-danger">500</h1>
    <h3 class="fw-bold">Server Error</h3>
    <p class="text-muted mb-4"><%= typeof message !== 'undefined' ? message : 'Something went wrong. Please try again later.' %></p>
    <a href="/home" class="btn btn-primary rounded-pill px-4"><i class="fas fa-home me-2"></i>Go Home</a>
  </div>
</section>
