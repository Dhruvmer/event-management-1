<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="EventPro - Professional Event Management System for Weddings, Birthdays, Corporate Events and more">
  <meta name="author" content="EventPro">
  <title><%= typeof title !== 'undefined' ? title : 'EventPro - Event Management' %></title>
  
  <!-- Bootstrap 5 -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <!-- Font Awesome 6 -->
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" rel="stylesheet">
  <!-- SweetAlert2 -->
  <link href="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.min.css" rel="stylesheet">
  <!-- Google Fonts -->
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800&family=Playfair+Display:wght@400;700&display=swap" rel="stylesheet">
  <!-- Animate.css -->
  <link href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css" rel="stylesheet">
  <!-- Custom CSS -->
  <link rel="stylesheet" href="/css/style.css">
  <%- typeof styles !== 'undefined' ? styles : '' %>
</head>
<body>
  <!-- Navbar -->
  <%- include('../partials/navbar') %>
  
  <!-- Flash Messages -->
  <div class="container mt-3">
    <% if (typeof success_msg !== 'undefined' && success_msg.length > 0) { %>
      <% success_msg.forEach(msg => { %>
        <div class="alert alert-success alert-dismissible fade show animate__animated animate__fadeInDown" role="alert">
          <i class="fas fa-check-circle me-2"></i><%= msg %>
          <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
      <% }) %>
    <% } %>
    
    <% if (typeof error_msg !== 'undefined' && error_msg.length > 0) { %>
      <% error_msg.forEach(msg => { %>
        <div class="alert alert-danger alert-dismissible fade show animate__animated animate__fadeInDown" role="alert">
          <i class="fas fa-exclamation-circle me-2"></i><%= msg %>
          <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
      <% }) %>
    <% } %>
    
    <% if (typeof warning_msg !== 'undefined' && warning_msg.length > 0) { %>
      <% warning_msg.forEach(msg => { %>
        <div class="alert alert-warning alert-dismissible fade show animate__animated animate__fadeInDown" role="alert">
          <i class="fas fa-exclamation-triangle me-2"></i><%= msg %>
          <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
      <% }) %>
    <% } %>
  </div>

  <!-- Main Content -->
  <main>
    <%- body %>
  </main>

  <!-- Footer -->
  <%- include('../partials/footer') %>

  <!-- Bootstrap JS -->
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
  <!-- SweetAlert2 -->
  <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
  <!-- Custom JS -->
  <script src="/js/main.js"></script>
  <script src="/js/sweetalert-helper.js"></script>
  <%- typeof scripts !== 'undefined' ? scripts : '' %>
</body>
</html>
