<div class="admin-topbar">
  <h4 class="fw-bold mb-0"><i class="fas fa-images me-2"></i>Add New Gallery</h4>
  <a href="/admin/gallery" class="btn btn-outline-secondary rounded-pill">
    <i class="fas fa-arrow-left me-2"></i>Back to Gallery
  </a>
</div>

<div class="card border-0 shadow-sm rounded-4">
  <div class="card-body p-4">
    <form action="/admin/gallery/add" method="POST" enctype="multipart/form-data" novalidate>
      <div class="row g-3">
        <!-- Basic Information -->
        <div class="col-12">
          <h5 class="fw-bold mb-3"><i class="fas fa-info-circle text-primary me-2"></i>Basic Information</h5>
        </div>
        
        <div class="col-md-8">
          <label class="form-label fw-500">Gallery Title *</label>
          <input type="text" name="title" class="form-control" required>
        </div>
        
        <div class="col-md-4">
          <label class="form-label fw-500">Category *</label>
          <select name="category" class="form-select" required>
            <option value="">Select Category</option>
            <option value="wedding">Wedding</option>
            <option value="corporate">Corporate</option>
            <option value="birthday">Birthday</option>
            <option value="conference">Conference</option>
            <option value="exhibition">Exhibition</option>
            <option value="concert">Concert</option>
            <option value="other">Other</option>
          </select>
        </div>
        
        <div class="col-12">
          <label class="form-label fw-500">Description</label>
          <textarea name="description" class="form-control" rows="4" placeholder="Describe this gallery..."></textarea>
        </div>
        
        <!-- Event Details -->
        <div class="col-12 mt-4">
          <h5 class="fw-bold mb-3"><i class="fas fa-calendar text-primary me-2"></i>Event Details</h5>
        </div>
        
        <div class="col-md-6">
          <label class="form-label fw-500">Venue</label>
          <input type="text" name="venue" class="form-control" placeholder="Event venue">
        </div>
        
        <div class="col-md-6">
          <label class="form-label fw-500">Event Date</label>
          <input type="date" name="eventDate" class="form-control">
        </div>
        
        <!-- Gallery Images -->
        <div class="col-12 mt-4">
          <h5 class="fw-bold mb-3"><i class="fas fa-images text-primary me-2"></i>Gallery Images</h5>
        </div>
        
        <div class="col-12">
          <label class="form-label fw-500">Upload Images *</label>
          <input type="file" name="galleryImages" class="form-control" multiple accept="image/*" required>
          <small class="text-muted">Select multiple images (JPG, PNG, WebP). Maximum 20 images.</small>
        </div>
        
        <!-- Options -->
        <div class="col-12 mt-4">
          <h5 class="fw-bold mb-3"><i class="fas fa-cog text-primary me-2"></i>Options</h5>
        </div>
        
        <div class="col-md-6">
          <div class="form-check">
            <input class="form-check-input" type="checkbox" name="isFeatured" value="true" id="isFeatured">
            <label class="form-check-label" for="isFeatured">
              Mark as Featured Gallery
            </label>
          </div>
        </div>
        
        <!-- Submit Button -->
        <div class="col-12 mt-4">
          <div class="d-flex gap-2">
            <button type="submit" class="btn btn-primary btn-lg rounded-pill" onclick="return confirm('Are you sure you want to create this gallery?')">
              <i class="fas fa-save me-2"></i>Create Gallery
            </button>
            <a href="/admin/gallery" class="btn btn-outline-secondary btn-lg rounded-pill">
              <i class="fas fa-times me-2"></i>Cancel
            </a>
          </div>
        </div>
      </div>
    </form>
  </div>
</div>
