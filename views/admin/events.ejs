<div class="admin-topbar">
  <h4 class="fw-bold mb-0"><i class="fas fa-calendar-alt me-2"></i>Event Management</h4>
  <div class="d-flex gap-2">
    <a href="/admin/events/add" class="btn btn-primary rounded-pill"><i class="fas fa-plus me-2"></i>Add Event</a>
  </div>
</div>

<!-- Filters -->
<div class="d-flex gap-2 mb-4">
  <form action="/admin/events" method="GET" class="d-flex gap-2 flex-grow-1">
    <input type="text" name="search" class="form-control rounded-pill" placeholder="Search events..." value="<%= searchQuery %>">
    <select name="category" class="form-select rounded-pill" style="width:auto;">
      <option value="all">All Categories</option>
      <option value="wedding" <%= currentCategory === 'wedding' ? 'selected' : '' %>>Wedding</option>
      <option value="birthday" <%= currentCategory === 'birthday' ? 'selected' : '' %>>Birthday</option>
      <option value="corporate" <%= currentCategory === 'corporate' ? 'selected' : '' %>>Corporate</option>
      <option value="concert" <%= currentCategory === 'concert' ? 'selected' : '' %>>Concert</option>
      <option value="conference" <%= currentCategory === 'conference' ? 'selected' : '' %>>Conference</option>
    </select>
    <button type="submit" class="btn btn-primary rounded-pill"><i class="fas fa-search"></i></button>
  </form>
</div>

<div class="row g-4">
  <% events.forEach(event => { %>
    <div class="col-lg-4 col-md-6">
      <div class="card border-0 shadow-sm rounded-4 h-100 overflow-hidden">
        <img src="<%= event.eventImage %>" alt="<%= event.title %>" class="card-img-top" style="height:180px;object-fit:cover;"
             onerror="this.src='/images/default-event.jpg'">
        <div class="card-body p-4">
          <div class="d-flex justify-content-between align-items-start mb-2">
            <span class="badge bg-primary bg-opacity-10 text-primary"><%= getCategoryName(event.category) %></span>
            <div>
              <% if (event.isActive) { %><span class="badge bg-success">Active</span><% } else { %><span class="badge bg-danger">Inactive</span><% } %>
              <% if (event.isFeatured) { %><span class="badge bg-warning">Featured</span><% } %>
            </div>
          </div>
          <h6 class="fw-bold"><%= event.title %></h6>
          <p class="text-primary fw-bold">₹<%= event.pricing.basePrice.toLocaleString('en-IN') %> | <small class="text-muted"><%= event.totalBookings %> bookings</small></p>
        </div>
        <div class="card-footer bg-transparent border-0 p-4 pt-0 d-flex gap-2">
          <a href="/admin/events/edit/<%= event._id %>" class="btn btn-outline-primary btn-sm flex-grow-1 rounded-pill">
            <i class="fas fa-edit me-1"></i>Edit
          </a>
          <form action="/admin/events/delete/<%= event._id %>" method="POST" class="flex-grow-1">
            <button type="submit" class="btn btn-outline-danger btn-sm w-100 rounded-pill" onclick="return confirm('Are you sure you want to delete this event: <%= event.title %>? This action cannot be undone and will remove all associated bookings.')">
              <i class="fas fa-trash me-1"></i>Delete
            </button>
          </form>
        </div>
      </div>
    </div>
  <% }) %>
</div>

<% if (events.length === 0) { %>
  <div class="text-center py-5">
    <i class="fas fa-calendar-plus fa-3x text-muted mb-3"></i>
    <h5 class="text-muted">No events found</h5>
    <a href="/admin/events/add" class="btn btn-primary rounded-pill mt-2">Add First Event</a>
  </div>
<% } %>
