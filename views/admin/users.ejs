<div class="admin-topbar">
  <h4 class="fw-bold mb-0"><i class="fas fa-users me-2"></i>User Management</h4>
  <div class="d-flex gap-2">
    <a href="/admin/users/add" class="btn btn-success rounded-pill">
      <i class="fas fa-user-plus me-2"></i>Add New User
    </a>
    <form action="/admin/users" method="GET" class="d-flex gap-2">
      <input type="text" name="search" class="form-control rounded-pill" placeholder="Search users..." value="<%= searchQuery %>">
      <select name="status" class="form-select rounded-pill" style="width:auto;">
        <option value="all" <%= currentStatus === 'all' ? 'selected' : '' %>>All</option>
        <option value="active" <%= currentStatus === 'active' ? 'selected' : '' %>>Active</option>
        <option value="inactive" <%= currentStatus === 'inactive' ? 'selected' : '' %>>Inactive</option>
      </select>
      <button type="submit" class="btn btn-primary rounded-pill"><i class="fas fa-search"></i></button>
    </form>
  </div>
</div>

<div class="card border-0 shadow-sm rounded-4">
  <div class="card-body p-0">
    <div class="table-responsive">
      <table class="table table-hover align-middle mb-0">
        <thead class="bg-light">
          <tr>
            <th class="ps-4">User</th>
            <th>Email</th>
            <th>Phone</th>
            <th>Location</th>
            <th>Status</th>
            <th>Joined</th>
            <th>Logins</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody>
          <% users.forEach(user => { %>
            <tr>
              <td class="ps-4">
                <div class="d-flex align-items-center">
                  <img src="<%= user.profileImage %>" class="rounded-circle me-2" width="36" height="36" style="object-fit:cover;"
                       onerror="this.src='/images/default-avatar.png'">
                  <strong><%= user.fullName %></strong>
                </div>
              </td>
              <td><%= user.email %></td>
              <td><%= user.phone %></td>
              <td><%= user.address?.city || '-' %></td>
              <td>
                <span class="badge bg-<%= user.isActive ? 'success' : 'danger' %>">
                  <%= user.isActive ? 'Active' : 'Inactive' %>
                </span>
              </td>
              <td><small><%= new Date(user.createdAt).toLocaleDateString('en-IN') %></small></td>
              <td><%= user.loginCount %></td>
              <td>
                <div class="d-flex gap-1">
                  <a href="/admin/users/edit/<%= user._id %>" class="btn btn-sm btn-outline-primary rounded-pill">
                    <i class="fas fa-edit"></i>
                  </a>
                  <form action="/admin/users/<%= user._id %>/toggle-status" method="POST" class="d-inline" id="toggleForm<%= user._id %>">
                    <button type="submit" class="btn btn-sm btn-outline-<%= user.isActive ? 'danger' : 'success' %> rounded-pill">
                      <i class="fas fa-<%= user.isActive ? 'ban' : 'check' %>"></i>
                    </button>
                  </form>
                  <script>
                    document.getElementById('toggleForm<%= user._id %>').addEventListener('submit', function(e) {
                      e.preventDefault();
                      confirmUserAction('<%= user.isActive ? "deactivate" : "activate" %>', '<%= user.fullName %>').then((result) => {
                        if (result.isConfirmed) {
                          this.submit();
                        }
                      });
                    });
                  </script>
                </div>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>
</div>

<!-- Pagination -->
<% if (pagination.totalPages > 1) { %>
  <nav class="mt-4">
    <ul class="pagination justify-content-center">
      <% for(let i = 1; i <= pagination.totalPages; i++) { %>
        <li class="page-item <%= i === pagination.currentPage ? 'active' : '' %>">
          <a class="page-link" href="/admin/users?page=<%= i %>&search=<%= searchQuery %>&status=<%= currentStatus %>"><%= i %></a>
        </li>
      <% } %>
    </ul>
  </nav>
<% } %>

<div class="text-muted text-center mt-2">
  <small>Total: <%= pagination.total %> users | Page <%= pagination.currentPage %> of <%= pagination.totalPages %></small>
</div>
