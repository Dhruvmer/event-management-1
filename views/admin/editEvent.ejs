<div class="admin-topbar">
  <h4 class="fw-bold mb-0"><i class="fas fa-edit me-2"></i>Edit Event</h4>
  <a href="/admin/events" class="btn btn-outline-secondary rounded-pill"><i class="fas fa-arrow-left me-1"></i>Back</a>
</div>

<form action="/admin/events/edit/<%= event._id %>" method="POST" enctype="multipart/form-data">
  <div class="row g-4">
    <div class="col-lg-8">
      <div class="card border-0 shadow-sm rounded-4 p-4 mb-4">
        <h6 class="fw-bold mb-3">Basic Information</h6>
        <div class="row g-3">
          <div class="col-12">
            <label class="form-label">Event Title *</label>
            <input type="text" name="title" class="form-control form-control-lg" value="<%= event.title %>" required>
          </div>
          <div class="col-md-6">
            <label class="form-label">Category *</label>
            <select name="category" class="form-select form-select-lg" required>
              <% ['wedding','birthday','corporate','concert','conference','anniversary','baby-shower','engagement','graduation','festival','charity','other'].forEach(cat => { %>
                <option value="<%= cat %>" <%= event.category === cat ? 'selected' : '' %>><%= cat.charAt(0).toUpperCase() + cat.slice(1) %></option>
              <% }) %>
            </select>
          </div>
          <div class="col-md-6">
            <label class="form-label">Duration</label>
            <input type="text" name="duration" class="form-control form-control-lg" value="<%= event.duration %>">
          </div>
          <div class="col-12">
            <label class="form-label">Short Description</label>
            <input type="text" name="shortDescription" class="form-control" value="<%= event.shortDescription || '' %>" maxlength="300">
          </div>
          <div class="col-12">
            <label class="form-label">Full Description *</label>
            <textarea name="description" class="form-control" rows="6" required><%= event.description %></textarea>
          </div>
        </div>
      </div>

      <div class="card border-0 shadow-sm rounded-4 p-4 mb-4">
        <h6 class="fw-bold mb-3">Pricing</h6>
        <div class="row g-3">
          <div class="col-md-4">
            <label class="form-label">Base Price (₹) *</label>
            <input type="number" name="basePrice" class="form-control form-control-lg" required value="<%= event.pricing.basePrice %>">
          </div>
          <div class="col-md-4">
            <label class="form-label">Premium Price (₹)</label>
            <input type="number" name="premiumPrice" class="form-control form-control-lg" value="<%= event.pricing.premiumPrice || '' %>">
          </div>
          <div class="col-md-4">
            <label class="form-label">Luxury Price (₹)</label>
            <input type="number" name="luxuryPrice" class="form-control form-control-lg" value="<%= event.pricing.luxuryPrice || '' %>">
          </div>
        </div>
      </div>

      <div class="card border-0 shadow-sm rounded-4 p-4 mb-4">
        <h6 class="fw-bold mb-3">Venue Details</h6>
        <div class="row g-3">
          <div class="col-md-6"><input type="text" name="venueName" class="form-control" value="<%= event.venue?.name || '' %>" placeholder="Venue Name"></div>
          <div class="col-md-6"><input type="text" name="venueCity" class="form-control" value="<%= event.venue?.city || '' %>" placeholder="City"></div>
          <div class="col-12"><input type="text" name="venueAddress" class="form-control" value="<%= event.venue?.address || '' %>" placeholder="Address"></div>
          <div class="col-md-6"><input type="text" name="venueState" class="form-control" value="<%= event.venue?.state || '' %>" placeholder="State"></div>
          <div class="col-md-6"><input type="number" name="venueCapacity" class="form-control" value="<%= event.venue?.capacity || 500 %>" placeholder="Capacity"></div>
        </div>
      </div>
    </div>

    <div class="col-lg-4">
      <div class="card border-0 shadow-sm rounded-4 p-4 sticky-top" style="top:20px;">
        <h6 class="fw-bold mb-3">Settings & Media</h6>
        <% if (event.eventImage) { %>
          <img src="<%= event.eventImage %>" alt="Current" class="img-fluid rounded-3 mb-3" onerror="this.style.display='none'">
        <% } %>
        <div class="mb-3">
          <label class="form-label">Change Event Image</label>
          <input type="file" name="eventImage" class="form-control" accept="image/*">
        </div>
        <div class="mb-3">
          <label class="form-label">Additional Images</label>
          <input type="file" name="eventImages" class="form-control" accept="image/*" multiple>
        </div>
        <div class="mb-3">
          <label class="form-label">Max Guests</label>
          <input type="number" name="maxGuests" class="form-control" value="<%= event.maxGuests %>" min="1">
        </div>
        <div class="form-check mb-2">
          <input type="checkbox" name="isActive" class="form-check-input" id="isActive" <%= event.isActive ? 'checked' : '' %>>
          <label class="form-check-label" for="isActive">Active</label>
        </div>
        <div class="form-check mb-3">
          <input type="checkbox" name="isFeatured" class="form-check-input" id="isFeatured" <%= event.isFeatured ? 'checked' : '' %>>
          <label class="form-check-label" for="isFeatured">Featured</label>
        </div>
        <button type="submit" class="btn btn-primary btn-lg w-100 rounded-pill">
          <i class="fas fa-save me-2"></i>Update Event
        </button>
      </div>
    </div>
  </div>
</form>
