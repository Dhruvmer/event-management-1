<section style="margin-top:80px;min-height:100vh;background:linear-gradient(135deg,#f8f9fa 0%,#e9ecef 100%);">
  <!-- Hero Section -->
  <div class="hero-section text-center text-white py-5 mb-5" style="background:linear-gradient(135deg,#667eea 0%,#764ba2 100%);position:relative;overflow:hidden;">
    <div class="hero-pattern" style="position:absolute;top:0;left:0;width:100%;height:100%;opacity:0.1;background-image:url('data:image/svg+xml,%3Csvg width="60" height="60" viewBox="0 0 60 60" xmlns="http://www.w3.org/2000/svg"%3E%3Cg fill="none" fill-rule="evenodd"%3E%3Cg fill="%23ffffff" fill-opacity="0.4"%3E%3Ccircle cx="30" cy="30" r="4"/%3E%3C/g%3E%3C/g%3E%3C/svg%3E');"></div>
    <div class="container position-relative">
      <div class="animate__animated animate__fadeInDown">
        <h1 class="display-3 fw-bold mb-3">Our <span class="gallery-title">Gallery</span></h1>
        <p class="lead mb-4 opacity-90" style="font-size:1.2rem;">Browse through our portfolio of spectacular events and memorable celebrations</p>
        <div class="d-flex justify-content-center gap-3">
          <div class="stat-item">
            <h3 class="fw-bold mb-0">500+</h3>
            <small class="opacity-75">Events</small>
          </div>
          <div class="stat-item">
            <h3 class="fw-bold mb-0">50+</h3>
            <small class="opacity-75">Categories</small>
          </div>
          <div class="stat-item">
            <h3 class="fw-bold mb-0">100%</h3>
            <small class="opacity-75">Satisfaction</small>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="container">
    <!-- Category Filter -->
    <div class="text-center mb-5">
      <div class="d-inline-flex flex-wrap gap-2 p-3 bg-white rounded-4 shadow-sm" style="background:rgba(255,255,255,0.9);backdrop-filter:blur(10px);">
        <a href="/events/gallery" class="btn btn-sm rounded-pill px-4 py-2 <%= currentCategory === 'all' ? 'btn-primary' : 'btn-outline-primary' %>">
          <i class="fas fa-th me-2"></i>All
        </a>
        <% categories.forEach(cat => { %>
          <a href="/events/gallery?category=<%= cat %>" class="btn btn-sm rounded-pill px-4 py-2 <%= currentCategory === cat ? 'btn-primary' : 'btn-outline-primary' %>">
            <%= getCategoryIcon(cat) %>
            <%= getCategoryName(cat) %>
          </a>
        <% }) %>
      </div>
    </div>

    <% if (galleries.length === 0) { %>
      <div class="text-center py-5">
        <div class="empty-state max-width-500 mx-auto">
          <div class="mb-4">
            <i class="fas fa-images fa-5x text-muted opacity-50"></i>
          </div>
          <h3 class="text-muted mb-3">No Gallery Items Yet</h3>
          <p class="text-muted mb-4">We're working on adding amazing event photos. Check back soon!</p>
          <a href="/events" class="btn btn-primary rounded-pill px-4">
            <i class="fas fa-calendar-alt me-2"></i>Browse Events
          </a>
        </div>
      </div>
    <% } else { %>
      <div class="row g-4 mb-5">
        <% galleries.forEach((gallery, index) => { %>
          <div class="col-lg-4 col-md-6 gallery-item animate__animated animate__fadeInUp" style="animation-delay: '<%= index * 0.1 %>'s;">
            <a href="/events/gallery/<%= gallery._id %>" class="text-decoration-none">
              <div class="gallery-card-modern h-100">
                <div class="image-container position-relative">
                  <% if (gallery.images && gallery.images.length > 0) { %>
                    <img src="<%= gallery.images[0].url %>" alt="<%= gallery.title %>" class="main-image w-100" 
                         style="height:300px;object-fit:cover;" onerror="this.src='/images/default-event.jpg'">
                    <div class="image-overlay"></div>
                    
                    <!-- Badges -->
                    <div class="position-absolute top-0 start-0 m-3 d-flex flex-column gap-2">
                      <% if (gallery.isFeatured) { %>
                        <span class="badge bg-warning text-dark px-3 py-2 rounded-pill">
                          <i class="fas fa-star me-1"></i>Featured
                        </span>
                      <% } %>
                      <span class="badge bg-white text-dark px-3 py-2 rounded-pill">
                        <%= getCategoryIcon(gallery.category) %> <%= getCategoryName(gallery.category) %>
                      </span>
                    </div>
                    
                    <% if (gallery.images.length > 1) { %>
                      <div class="position-absolute top-0 end-0 m-3">
                        <span class="badge bg-dark bg-opacity-75 px-3 py-2 rounded-pill">
                          <i class="fas fa-images me-1"></i><%= gallery.images.length %> Photos
                        </span>
                      </div>
                    <% } %>
                    
                    <!-- Quick Actions -->
                    <div class="position-absolute bottom-0 end-0 m-3">
                      <div class="action-buttons">
                        <button class="btn btn-light btn-sm rounded-circle me-2">
                          <i class="fas fa-heart"></i>
                        </button>
                        <button class="btn btn-light btn-sm rounded-circle">
                          <i class="fas fa-share"></i>
                        </button>
                      </div>
                    </div>
                  <% } else { %>
                    <div class="no-image-placeholder d-flex align-items-center justify-content-center" style="height:300px;background:linear-gradient(135deg,#f8f9fa,#e9ecef);">
                      <div class="text-center">
                        <i class="fas fa-image fa-3x text-muted mb-3"></i>
                        <p class="text-muted">No Images Available</p>
                      </div>
                    </div>
                  <% } %>
                </div>
                
                <div class="content-section p-4">
                  <div class="mb-3">
                    <h5 class="fw-bold mb-2 text-truncate"><%= gallery.title %></h5>
                    <% if (gallery.description) { %>
                      <p class="text-muted small mb-3" style="line-height:1.5;"><%= gallery.description.substring(0, 80) %>...</p>
                    <% } %>
                  </div>
                  
                  <div class="event-details">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                      <% if (gallery.venue) { %>
                        <small class="text-muted">
                          <i class="fas fa-map-marker-alt me-1 text-primary"></i>
                          <span class="text-truncate d-inline-block" style="max-width:150px;"><%= gallery.venue %></span>
                        </small>
                      <% } %>
                      <% if (gallery.client) { %>
                        <small class="text-muted">
                          <i class="fas fa-user me-1 text-primary"></i>
                          <span class="text-truncate d-inline-block" style="max-width:100px;"><%= gallery.client %></span>
                        </small>
                      <% } %>
                    </div>
                    
                    <% if (gallery.tags && gallery.tags.length > 0) { %>
                      <div class="d-flex flex-wrap gap-1 mb-3">
                        <% gallery.tags.slice(0, 3).forEach(tag => { %>
                          <span class="badge bg-light text-dark small">#<%= tag %></span>
                        <% }) %>
                      </div>
                    <% } %>
                  </div>
                  
                  <% if (gallery.images && gallery.images.length > 1) { %>
                    <div class="thumbnail-preview">
                      <div class="d-flex gap-2">
                        <% gallery.images.slice(1, 4).forEach(img => { %>
                          <img src="<%= img.url %>" alt="Gallery" class="rounded-2" style="width:60px;height:40px;object-fit:cover;border:2px solid #fff;"
                               onerror="this.src='/images/default-event.jpg'">
                        <% }) %>
                        <% if (gallery.images.length > 4) { %>
                          <div class="rounded-2 d-flex align-items-center justify-content-center more-photos" 
                               style="width:60px;height:40px;background:#6c63ff;color:#fff;">
                            <small class="fw-bold">+<%= gallery.images.length - 4 %></small>
                          </div>
                        <% } %>
                      </div>
                    </div>
                  <% } %>
                </div>
              </div>
            </a>
          </div>
        <% }) %>
      </div>

      <!-- Pagination -->
      <% if (pagination.totalPages > 1) { %>
        <nav class="mt-5">
          <ul class="pagination justify-content-center gap-2">
            <% if (pagination.currentPage > 1) { %>
              <li class="page-item">
                <a class="page-link rounded-pill px-4" href="/events/gallery?page=<%= pagination.currentPage - 1 %>&category=<%= currentCategory %>">
                  <i class="fas fa-chevron-left"></i>
                </a>
              </li>
            <% } %>
            
            <% for(let i = 1; i <= pagination.totalPages; i++) { %>
              <% if (i === 1 || i === pagination.totalPages || (i >= pagination.currentPage - 1 && i <= pagination.currentPage + 1)) { %>
                <li class="page-item <%= i === pagination.currentPage ? 'active' : '' %>">
                  <a class="page-link rounded-pill px-4 <%= i === pagination.currentPage ? 'btn-primary' : 'btn-outline-primary' %>" 
                     href="/events/gallery?page=<%= i %>&category=<%= currentCategory %>"><%= i %></a>
                </li>
              <% } else if (i === pagination.currentPage - 2 || i === pagination.currentPage + 2) { %>
                <li class="page-item disabled">
                  <span class="page-link rounded-pill px-3">...</span>
                </li>
              <% } %>
            <% } %>
            
            <% if (pagination.currentPage < pagination.totalPages) { %>
              <li class="page-item">
                <a class="page-link rounded-pill px-4" href="/events/gallery?page=<%= pagination.currentPage + 1 %>&category=<%= currentCategory %>">
                  <i class="fas fa-chevron-right"></i>
                </a>
              </li>
            <% } %>
          </ul>
        </nav>
      <% } %>
    <% } %>
  </div>
</section>

<style>
/* Gallery Modern Styles */
.gallery-card-modern {
  background: #fff;
  border-radius: 16px;
  overflow: hidden;
  box-shadow: 0 4px 20px rgba(0,0,0,0.08);
  transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
  border: 1px solid rgba(0,0,0,0.05);
}

.gallery-card-modern:hover {
  transform: translateY(-8px) scale(1.02);
  box-shadow: 0 12px 40px rgba(0,0,0,0.15);
}

.image-container {
  position: relative;
  overflow: hidden;
}

.main-image {
  transition: transform 0.6s ease;
}

.gallery-card-modern:hover .main-image {
  transform: scale(1.1);
}

.image-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(to bottom, transparent 0%, rgba(0,0,0,0.3) 100%);
  opacity: 0;
  transition: opacity 0.3s ease;
}

.gallery-card-modern:hover .image-overlay {
  opacity: 1;
}

.action-buttons {
  opacity: 0;
  transform: translateY(20px);
  transition: all 0.3s ease;
}

.gallery-card-modern:hover .action-buttons {
  opacity: 1;
  transform: translateY(0);
}

.action-buttons button {
  transition: all 0.3s ease;
}

.action-buttons button:hover {
  transform: scale(1.1);
  background: #6c63ff !important;
  color: #fff !important;
}

.content-section {
  background: #fff;
}

.gallery-card-modern h5 {
  color: #2c3e50;
  transition: color 0.3s ease;
  font-size: 1.1rem;
}

.gallery-card-modern:hover h5 {
  color: #6c63ff;
}

.more-photos {
  background: linear-gradient(135deg, #6c63ff, #8b5cf6) !important;
}

.thumbnail-preview img {
  transition: transform 0.3s ease;
}

.thumbnail-preview img:hover {
  transform: scale(1.1);
}

/* Hero Section Styles */
.hero-section {
  position: relative;
}

.stat-item {
  margin: 0 20px;
}

.stat-item h3 {
  font-size: 2.5rem;
  font-weight: 700;
}

/* Empty State */
.empty-state {
  padding: 60px 20px;
}

.max-width-500 {
  max-width: 500px;
}

/* Responsive */
@media (max-width: 768px) {
  .stat-item {
    margin: 0 10px;
  }
  
  .stat-item h3 {
    font-size: 2rem;
  }
  
  .gallery-card-modern {
    margin-bottom: 20px;
  }
}

/* Gallery Title */
.gallery-title {
  background: linear-gradient(45deg, #fff, #ffd700);
  background-clip: text;
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  display: inline-block;
}

/* Animation Classes */
.animate__animated {
  animation-duration: 1s;
  animation-fill-mode: both;
}

.animate__fadeInUp {
  animation-name: fadeInUp;
}

@keyframes fadeInUp {
  from {
    opacity: 0;
    transform: translateY(30px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.animate__fadeInDown {
  animation-name: fadeInDown;
}

@keyframes fadeInDown {
  from {
    opacity: 0;
    transform: translateY(-30px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}
</style>
