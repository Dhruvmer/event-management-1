<section style="margin-top:80px;min-height:100vh;" class="bg-light py-5">
  <div class="container">
    <div class="row justify-content-center">
      <div class="col-lg-7">
        <div class="card border-0 shadow-lg rounded-4 overflow-hidden text-center">
          <!-- Success Header -->
          <div class="p-5" style="background:linear-gradient(135deg,#28a745,#20c997);">
            <div class="mb-3">
              <i class="fas fa-check-circle fa-5x text-white animate__animated animate__bounceIn"></i>
            </div>
            <h2 class="text-white fw-bold">Booking Confirmed!</h2>
            <p class="text-white opacity-75">Your event has been successfully booked</p>
            <span class="badge bg-white text-success fs-6 px-4 py-2"><%= booking.bookingId %></span>
          </div>

          <div class="card-body p-4 p-md-5">
            <!-- Booking Details -->
            <div class="text-start">
              <h5 class="fw-bold mb-3">Booking Details</h5>
              <table class="table table-borderless">
                <tr><td class="text-muted">Event:</td><td class="fw-bold"><%= booking.event?.title || 'Event' %></td></tr>
                <tr><td class="text-muted">Date:</td><td><%= new Date(booking.eventDate).toLocaleDateString('en-IN', { dateStyle: 'long' }) %></td></tr>
                <tr><td class="text-muted">Time:</td><td><%= booking.eventTime %></td></tr>
                <tr><td class="text-muted">Guests:</td><td><%= booking.guestCount %></td></tr>
                <tr><td class="text-muted">Package:</td><td><%= booking.selectedPackage?.name %></td></tr>
                <tr><td class="text-muted">Contact:</td><td><%= booking.contactName %></td></tr>
                <tr><td class="text-muted">Email:</td><td><%= booking.contactEmail %></td></tr>
                <% if (booking.venueName) { %>
                  <tr><td class="text-muted">Venue:</td><td><%= booking.venueName %></td></tr>
                <% } %>
              </table>

              <hr>

              <!-- Payment Info -->
              <h5 class="fw-bold mb-3">Payment Summary</h5>
              <div class="d-flex justify-content-between mb-2">
                <span class="text-muted">Subtotal:</span>
                <span>₹<%= (booking.subtotal || 0).toLocaleString('en-IN') %></span>
              </div>
              <div class="d-flex justify-content-between mb-2">
                <span class="text-muted">GST (18%):</span>
                <span>₹<%= (booking.tax || 0).toLocaleString('en-IN') %></span>
              </div>
              <div class="d-flex justify-content-between mb-3">
                <span class="fw-bold fs-5">Total Paid:</span>
                <span class="fw-bold fs-5 text-success">₹<%= (booking.totalAmount || 0).toLocaleString('en-IN') %></span>
              </div>

              <div class="alert alert-success rounded-3">
                <i class="fas fa-check-circle me-2"></i>
                <strong>Payment Status:</strong> <%= booking.paymentStatus.charAt(0).toUpperCase() + booking.paymentStatus.slice(1) %>
                <% if (booking.razorpayPaymentId) { %>
                  <br><small>Payment ID: <%= booking.razorpayPaymentId %></small>
                <% } %>
              </div>
            </div>

            <!-- Actions -->
            <div class="d-flex gap-3 mt-4">
              <a href="/bookings/download-pdf/<%= booking._id %>" class="btn btn-primary flex-grow-1 rounded-pill">
                <i class="fas fa-file-pdf me-2"></i>Download PDF
              </a>
              <a href="/bookings/my-bookings" class="btn btn-outline-primary flex-grow-1 rounded-pill">
                <i class="fas fa-list me-2"></i>My Bookings
              </a>
            </div>

            <p class="text-muted small mt-4">
              <i class="fas fa-envelope me-1"></i>A confirmation email with PDF has been sent to <strong><%= booking.contactEmail %></strong>
            </p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
