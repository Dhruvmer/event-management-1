<section style="margin-top:80px;min-height:100vh;">
  <!-- Gallery Hero -->
  <div class="position-relative" style="height:400px;overflow:hidden;">
    <% if (gallery.images && gallery.images.length > 0) { %>
      <img src="<%= gallery.images[0].url %>" alt="<%= gallery.title %>" class="w-100 h-100" style="object-fit:cover;filter:brightness(0.5);"
           onerror="this.src='/images/default-event.jpg'">
    <% } else { %>
      <div class="w-100 h-100 bg-dark"></div>
    <% } %>
    <div class="position-absolute top-0 start-0 w-100 h-100 d-flex align-items-center">
      <div class="container text-white">
        <span class="badge bg-primary mb-3 px-3 py-2"><%= getCategoryName(gallery.category) %></span>
        <h1 class="display-4 fw-bold"><%= gallery.title %></h1>
        <div class="d-flex align-items-center gap-4 mt-3">
          <% if (gallery.venue) { %>
            <span><i class="fas fa-map-marker-alt me-2"></i><%= gallery.venue %></span>
          <% } %>
          <% if (gallery.eventDate) { %>
            <span><i class="fas fa-calendar me-2"></i><%= new Date(gallery.eventDate).toLocaleDateString('en-IN') %></span>
          <% } %>
          <% if (gallery.isFeatured) { %>
            <span class="text-warning"><i class="fas fa-star me-2"></i>Featured</span>
          <% } %>
        </div>
      </div>
    </div>
  </div>

  <div class="container py-5">
    <div class="row g-4">
      <!-- Main Content -->
      <div class="col-lg-8">
        <!-- Description -->
        <% if (gallery.description) { %>
          <div class="card border-0 shadow-sm rounded-4 p-4 mb-4">
            <h4 class="fw-bold mb-3"><i class="fas fa-info-circle text-primary me-2"></i>About This Event</h4>
            <p class="text-muted" style="line-height:1.8;white-space:pre-line;"><%= gallery.description %></p>
          </div>
        <% } %>

        <!-- Gallery Images -->
        <% if (gallery.images && gallery.images.length > 0) { %>
          <div class="card border-0 shadow-sm rounded-4 p-4 mb-4">
            <h4 class="fw-bold mb-3"><i class="fas fa-images text-primary me-2"></i>Event Photos (<%= gallery.images.length %>)</h4>
            <div class="row g-3">
              <% gallery.images.forEach((image, index) => { %>
                <div class="col-md-6 col-lg-4">
                  <div class="gallery-item position-relative rounded-3 overflow-hidden" style="cursor:pointer;"
                       onclick="openImageModal('<%= image.url %>', '<%= gallery.title %> - Photo <%= index + 1 %>')">
                    <img src="<%= image.url %>" alt="Gallery Image <%= index + 1 %>" 
                         class="w-100 h-100" style="object-fit:cover;transition:transform 0.3s ease;"
                         onmouseover="this.style.transform='scale(1.05)'" 
                         onmouseout="this.style.transform='scale(1)'">
                    <div class="position-absolute top-50 start-50 translate-middle bg-dark bg-opacity-75 text-white rounded-circle p-2 d-none">
                      <i class="fas fa-expand"></i>
                    </div>
                  </div>
                </div>
              <% }) %>
            </div>
          </div>
        <% } %>
      </div>

      <!-- Sidebar -->
      <div class="col-lg-4">
        <!-- Quick Info -->
        <div class="card border-0 shadow-sm rounded-4 p-4 mb-4">
          <h5 class="fw-bold mb-3"><i class="fas fa-info text-primary me-2"></i>Quick Info</h5>
          <div class="space-y-3">
            <div class="d-flex justify-content-between">
              <span class="text-muted">Category:</span>
              <span class="fw-500"><%= getCategoryName(gallery.category) %></span>
            </div>
            <% if (gallery.venue) { %>
              <div class="d-flex justify-content-between">
                <span class="text-muted">Venue:</span>
                <span class="fw-500"><%= gallery.venue %></span>
              </div>
            <% } %>
            <% if (gallery.eventDate) { %>
              <div class="d-flex justify-content-between">
                <span class="text-muted">Event Date:</span>
                <span class="fw-500"><%= new Date(gallery.eventDate).toLocaleDateString('en-IN') %></span>
              </div>
            <% } %>
            <div class="d-flex justify-content-between">
              <span class="text-muted">Photos:</span>
              <span class="fw-500"><%= gallery.images ? gallery.images.length : 0 %></span>
            </div>
            <% if (gallery.isFeatured) { %>
              <div class="d-flex justify-content-between">
                <span class="text-muted">Status:</span>
                <span class="badge bg-warning">Featured</span>
              </div>
            <% } %>
          </div>
        </div>

        <!-- Actions -->
        <div class="card border-0 shadow-sm rounded-4 p-4 mb-4">
          <h5 class="fw-bold mb-3"><i class="fas fa-share-alt text-primary me-2"></i>Share</h5>
          <div class="d-flex gap-2">
            <a href="#" class="btn btn-outline-primary btn-sm rounded-circle" style="width:36px;height:36px;" title="Share on Facebook">
              <i class="fab fa-facebook-f"></i>
            </a>
            <a href="#" class="btn btn-outline-info btn-sm rounded-circle" style="width:36px;height:36px;" title="Share on Twitter">
              <i class="fab fa-twitter"></i>
            </a>
            <a href="#" class="btn btn-outline-success btn-sm rounded-circle" style="width:36px;height:36px;" title="Share on WhatsApp">
              <i class="fab fa-whatsapp"></i>
            </a>
            <button class="btn btn-outline-secondary btn-sm rounded-circle" style="width:36px;height:36px;" 
                    onclick="copyLink()" title="Copy Link">
              <i class="fas fa-link"></i>
            </button>
          </div>
        </div>
      </div>
    </div>

    <!-- Related Galleries -->
    <% if (relatedGalleries && relatedGalleries.length > 0) { %>
      <div class="mt-5">
        <h4 class="fw-bold mb-4"><i class="fas fa-images text-primary me-2"></i>Related Galleries</h4>
        <div class="row g-4">
          <% relatedGalleries.forEach(related => { %>
            <div class="col-lg-4 col-md-6">
              <a href="/events/gallery/<%= related._id %>" class="text-decoration-none">
                <div class="card border-0 shadow-sm rounded-4 overflow-hidden h-100">
                  <% if (related.images && related.images.length > 0) { %>
                    <img src="<%= related.images[0].url %>" alt="<%= related.title %>" class="card-img-top" 
                         style="height:200px;object-fit:cover;" onerror="this.src='/images/default-event.jpg'">
                  <% } %>
                  <div class="card-body p-3">
                    <h6 class="fw-bold text-dark mb-2"><%= related.title %></h6>
                    <small class="text-muted"><%= getCategoryName(related.category) %></small>
                  </div>
                </div>
              </a>
            </div>
          <% }) %>
        </div>
      </div>
    <% } %>

    <!-- Back Button -->
    <div class="text-center mt-5">
      <a href="/events/gallery" class="btn btn-outline-primary rounded-pill btn-lg">
        <i class="fas fa-arrow-left me-2"></i>Back to Gallery
      </a>
    </div>
  </div>
</section>

<!-- Image Modal -->
<div class="modal fade" id="imageModal" tabindex="-1">
  <div class="modal-dialog modal-lg modal-dialog-centered">
    <div class="modal-content bg-transparent border-0">
      <div class="modal-body p-0">
        <button type="button" class="btn-close btn-close-white position-absolute top-0 end-0 m-3 z-1" data-bs-dismiss="modal"></button>
        <img id="modalImage" src="" alt="" class="w-100 rounded">
      </div>
    </div>
  </div>
</div>

<style>
.gallery-item:hover .d-none {
  display: flex !important;
}
.space-y-3 > * + * {
  margin-top: 1rem;
}
</style>

<script>
function openImageModal(imageUrl, title) {
  document.getElementById('modalImage').src = imageUrl;
  document.getElementById('modalImage').alt = title;
  new bootstrap.Modal(document.getElementById('imageModal')).show();
}

function copyLink() {
  navigator.clipboard.writeText(window.location.href).then(() => {
    alert('Link copied to clipboard!');
  });
}
</script>
