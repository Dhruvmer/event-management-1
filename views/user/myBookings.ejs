<section style="margin-top:80px;min-height:100vh;" class="bg-light">
  <div class="page-header py-4 text-white" style="background:linear-gradient(135deg,#1a1a2e,#16213e);">
    <div class="container">
      <h2 class="fw-bold"><i class="fas fa-ticket-alt me-2"></i>My Bookings</h2>
    </div>
  </div>
  <div class="container py-4">
    <!-- Filter Tabs -->
    <div class="d-flex gap-2 mb-4 flex-wrap">
      <a href="/bookings/my-bookings" class="btn btn-sm rounded-pill <%= currentStatus === 'all' ? 'btn-primary' : 'btn-outline-primary' %>">All</a>
      <a href="/bookings/my-bookings?status=pending" class="btn btn-sm rounded-pill <%= currentStatus === 'pending' ? 'btn-warning' : 'btn-outline-warning' %>">Pending</a>
      <a href="/bookings/my-bookings?status=confirmed" class="btn btn-sm rounded-pill <%= currentStatus === 'confirmed' ? 'btn-success' : 'btn-outline-success' %>">Confirmed</a>
      <a href="/bookings/my-bookings?status=completed" class="btn btn-sm rounded-pill <%= currentStatus === 'completed' ? 'btn-info' : 'btn-outline-info' %>">Completed</a>
      <a href="/bookings/my-bookings?status=cancelled" class="btn btn-sm rounded-pill <%= currentStatus === 'cancelled' ? 'btn-danger' : 'btn-outline-danger' %>">Cancelled</a>
    </div>

    <% if (bookings.length === 0) { %>
      <div class="text-center py-5">
        <i class="fas fa-ticket-alt fa-4x text-muted mb-3"></i>
        <h4 class="text-muted">No bookings found</h4>
        <a href="/events" class="btn btn-primary rounded-pill mt-2">Browse Events</a>
      </div>
    <% } else { %>
      <% bookings.forEach(booking => { %>
        <div class="card border-0 shadow-sm rounded-4 mb-3 overflow-hidden">
          <div class="card-body p-4">
            <div class="row align-items-center">
              <div class="col-auto d-none d-md-block">
                <img src="<%= booking.event?.eventImage || '/images/default-event.jpg' %>" alt="Event" 
                     class="rounded-3" style="width:80px;height:80px;object-fit:cover;"
                     onerror="this.src='/images/default-event.jpg'">
              </div>
              <div class="col">
                <div class="d-flex justify-content-between align-items-start">
                  <div>
                    <h5 class="fw-bold mb-1"><%= booking.event?.title || 'Event' %></h5>
                    <span class="badge bg-<%= booking.status === 'confirmed' ? 'success' : booking.status === 'pending' ? 'warning' : booking.status === 'completed' ? 'info' : 'danger' %> me-2">
                      <%= booking.status.charAt(0).toUpperCase() + booking.status.slice(1) %>
                    </span>
                    <span class="badge bg-<%= booking.paymentStatus === 'completed' ? 'success' : booking.paymentStatus === 'pending' ? 'warning' : 'danger' %>">
                      Payment: <%= booking.paymentStatus %>
                    </span>
                  </div>
                  <span class="text-primary fw-bold fs-5">₹<%= (booking.totalAmount || 0).toLocaleString('en-IN') %></span>
                </div>
                <div class="row mt-2">
                  <div class="col-auto"><small class="text-muted"><i class="fas fa-hashtag me-1"></i><%= booking.bookingId %></small></div>
                  <div class="col-auto"><small class="text-muted"><i class="fas fa-calendar me-1"></i><%= new Date(booking.eventDate).toLocaleDateString('en-IN') %></small></div>
                  <div class="col-auto"><small class="text-muted"><i class="fas fa-users me-1"></i><%= booking.guestCount %> guests</small></div>
                  <div class="col-auto"><small class="text-muted"><i class="fas fa-box me-1"></i><%= booking.selectedPackage?.name %></small></div>
                </div>
              </div>
              <div class="col-auto">
                <div class="d-flex gap-2 flex-column">
                  <a href="/bookings/confirmation/<%= booking._id %>" class="btn btn-outline-primary btn-sm rounded-pill">
                    <i class="fas fa-eye me-1"></i>View
                  </a>
                  <% if (booking.paymentStatus === 'completed') { %>
                    <a href="/bookings/download-pdf/<%= booking._id %>" class="btn btn-outline-danger btn-sm rounded-pill">
                      <i class="fas fa-file-pdf me-1"></i>PDF
                    </a>
                  <% } %>
                  <% if (['pending', 'confirmed'].includes(booking.status)) { %>
                    <form action="/bookings/cancel/<%= booking._id %>" method="POST" onsubmit="return confirm('Are you sure you want to cancel this booking: <%= booking.event?.title %>? This action cannot be undone.')">
                      <button type="submit" class="btn btn-outline-danger btn-sm rounded-pill w-100">
                        <i class="fas fa-times me-1"></i>Cancel
                      </button>
                    </form>
                  <% } %>
                </div>
              </div>
            </div>
          </div>
        </div>
      <% }) %>

      <!-- Pagination -->
      <% if (pagination.totalPages > 1) { %>
        <nav class="mt-4">
          <ul class="pagination justify-content-center">
            <% for(let i = 1; i <= pagination.totalPages; i++) { %>
              <li class="page-item <%= i === pagination.currentPage ? 'active' : '' %>">
                <a class="page-link rounded-pill" href="/bookings/my-bookings?page=<%= i %>&status=<%= currentStatus %>"><%= i %></a>
              </li>
            <% } %>
          </ul>
        </nav>
      <% } %>
    <% } %>
  </div>
</section>
